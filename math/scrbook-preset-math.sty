{\newline}                                   % HEADSPACE
{\thmname{#1}\thmnumber{ #2}\thmnote{ (#3)}} % CUSTOM-HEAD-SPEC

\newtheoremstyle{dotlessdefinition}
{\amsthmsep}                                 % ABOVESPACE
{\amsthmsep}                                 % BELOWSPACE
{\normalfont}                                % BODYFONT
{0pt}                                        % INDENT (empty value
%                                              is the same as 0pt)
{\(\rbullet\) \bfseries}                     % HEADFONT
{}                                           % HEADPUNCT
{\newline}                                   % HEADSPACE
{\thmname{#1}\thmnumber{ #2}\thmnote{ (#3)}} % CUSTOM-HEAD-SPEC

\newtheoremstyle{dotlessremark}
{0.5\amsthmsep}                              % ABOVESPACE
{0.5\amsthmsep}                              % BELOWSPACE
{\normalfont}                                % BODYFONT
{0pt}                                        % INDENT (empty value
%                                              is the same as 0pt)
{\itshape}                                   % HEADFONT
{}                                           % HEADPUNCT
{\newline}                                   % HEADSPACE
{}                                           % CUSTOM-HEAD-SPEC

\newtheoremstyle{custom}
{10pt}                                       % ABOVESPACE
{}                                           % BELOWSPACE
{\normalfont}                                % BODYFONT
{0pt}                                        % INDENT (empty value
